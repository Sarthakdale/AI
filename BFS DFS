
# --- DFS FUNCTION ---
def dfs(graph, node, visited):
    if node not in visited:
        print(node, end=" ")
        visited.add(node)
        # Sort neighbors alphabetically so the output is predictable
        for neighbor in sorted(graph[node]):
            dfs(graph, neighbor, visited)

# --- BFS FUNCTION ---
def bfs(graph, start):
    visited = set()
    queue = [start]
    bfs_order = []
    
    while queue:
        vertex = queue.pop(0)
        if vertex not in visited:
            visited.add(vertex)
            bfs_order.append(vertex)
            # Add neighbors that haven't been visited yet
            neighbors = sorted(list(graph[vertex]))
            for neighbor in neighbors:
                if neighbor not in visited:
                    queue.append(neighbor)
    return bfs_order

# Graph defined once using lists
graph = {
 'A': ['B', 'C'],
 'B': ['A', 'D', 'E'],
 'C': ['A', 'F', 'G'],
 'D': ['B'],
 'E': ['B'],
 'F': ['C'],
 'G': ['C']
}

# --- EXECUTION ---

print("DFS Traversal (Starting from A):")
dfs(graph, 'A', set())

print("\n\nBFS Traversal (Starting from A):")
bfs_result = bfs(graph, 'A')
print(" ".join(bfs_result))
